---
import "@/styles/global.css";
import "@fontsource/geist/400.css";
import "@fontsource/geist/500.css";
import "@fontsource/geist-mono/400.css";
import "@fontsource/geist-mono/500.css";

import Navbar from "@/components/layout/Navbar.astro";
import Footer from "@/components/layout/Footer.astro";
import { OG_HEIGHT, OG_WIDTH } from "@/lib/og-dimensions";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "PQC Coins - Post-Quantum Crypto Migration Tracker",
  description = "Track the percentage of cryptocurrency market cap that has migrated to post-quantum secure cryptography.",
} = Astro.props;

const siteOrigin = Astro.site?.origin ?? Astro.url.origin;
const ogImageUrl = new URL("/api/og", siteOrigin).href;
const pageUrl = new URL(Astro.url.pathname, siteOrigin).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={pageUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content={String(OG_WIDTH)} />
    <meta property="og:image:height" content={String(OG_HEIGHT)} />
    <meta property="og:image:alt" content="Post-quantum crypto migration tracker percentage" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content="Post-quantum crypto migration tracker percentage" />
  </head>
  <body>
    <Navbar />
    <main class="grow">
      <slot />
    </main>
    <Footer />
  </body>
</html>
